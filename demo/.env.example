# Demo stack environment — copy to .env, fill in, NEVER commit .env.
# This stack is PUBLIC. Strangers will paste xpubs here. Treat all data as ephemeral.

# Rails
RAILS_MASTER_KEY=replace-with-different-key-than-personal
SECRET_KEY_BASE=replace-with-different-secret-than-personal

# Postgres
POSTGRES_PASSWORD=generate-a-strong-random-password-different-from-personal

# ntfy.sh — public topic for the demo (advertised on the demo page)
NTFY_TOPIC=coldwatch-demo-public-testnet
NTFY_E2E_KEY=  # leave empty for the demo — public topic, no E2E

# Chain provider — testnet only for the demo
CHAIN_PROVIDER=mempool_space
MEMPOOL_NETWORK=testnet

# Confirmation thresholds
ALARM_CONFIRMATIONS=0
SETTLED_CONFIRMATIONS=6

# Demo enforcement (Rails reads these)
DEMO_SESSION_TTL_SECONDS=3600
DEMO_MAX_XPUBS_PER_HOUR=20  # rate-limit at the form level
