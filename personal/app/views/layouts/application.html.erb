<!DOCTYPE html>
<html lang="en" class="bg-paper">
  <head>
    <title><%= content_for(:title) || "coldwatch" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="color-scheme" content="light">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-paper text-ink antialiased min-h-screen flex flex-col font-sans">

    <%# Sticky header %>
    <header class="bg-paper border-b border-stone-200 sticky top-0 z-10">
      <div class="max-w-5xl mx-auto px-6 py-0">
        <div class="flex items-center justify-between h-14">

          <%# Wordmark — serif italic, Bitcoin orange %>
          <div class="flex items-center gap-4">
            <%= link_to root_path, class: "group flex items-center gap-2" do %>
              <%# Eye icon — inline SVG, ink %>
              <svg class="w-5 h-5 text-orange-brand shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z"/>
                <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="font-serif italic text-xl text-orange-brand leading-none tracking-tight">coldwatch</span>
            <% end %>
          </div>

          <%# Status indicator — v0 hardcoded %>
          <div id="connection-status" class="flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-stone-400 shrink-0"></span>
            <span class="text-xs text-stone-500 font-mono hidden sm:block">Day 7: live · CSV export</span>
          </div>

        </div>
      </div>
    </header>

    <%# Flash messages %>
    <div class="max-w-5xl w-full mx-auto px-6 pt-6">
      <% if notice %>
        <div class="mb-4 px-4 py-3 bg-sage/10 border border-sage/30 text-sage text-sm rounded-lg flex items-start gap-2.5">
          <svg class="w-4 h-4 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="mb-4 px-4 py-3 bg-rust/10 border border-rust/30 text-rust text-sm rounded-lg flex items-start gap-2.5">
          <svg class="w-4 h-4 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
          </svg>
          <%= alert %>
        </div>
      <% end %>
    </div>

    <main class="flex-1 max-w-5xl w-full mx-auto px-6 py-8">
      <%= yield %>
    </main>

    <footer class="border-t border-stone-200 mt-auto">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <span class="text-xs text-stone-400 font-mono">coldwatch</span>
        <span class="text-xs text-stone-400 font-serif italic">not a wallet &middot; watch-only</span>
      </div>
    </footer>

  </body>
</html>
