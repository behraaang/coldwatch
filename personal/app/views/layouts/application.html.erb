<!DOCTYPE html>
<html class="bg-zinc-950">
  <head>
    <title><%= content_for(:title) || "coldwatch" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="color-scheme" content="dark">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-zinc-950 text-zinc-100 antialiased min-h-screen flex flex-col">
    <header class="border-b border-zinc-800 bg-zinc-950 sticky top-0 z-10">
      <div class="max-w-5xl mx-auto px-6 py-0">
        <%# Top bar: wordmark + status indicator %>
        <div class="flex items-center justify-between h-14">
          <div class="flex items-center gap-3">
            <%= link_to root_path, class: "font-mono text-sm font-semibold tracking-widest text-zinc-100 hover:text-white uppercase" do %>
              coldwatch
            <% end %>
            <span class="hidden sm:block text-zinc-700 text-xs">|</span>
            <span class="hidden sm:block text-xs text-zinc-600 uppercase tracking-wider font-mono">watch-only</span>
          </div>

          <%# Status indicator — v0 hardcoded, replace with Turbo Stream when watcher is live %>
          <div id="connection-status" class="flex items-center gap-2">
            <%# Dot %>
            <span class="relative flex h-2 w-2">
              <span class="block h-2 w-2 rounded-full bg-zinc-600"></span>
            </span>
            <span class="text-xs text-zinc-500 font-mono">Not syncing yet &mdash; Day 4</span>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-1 max-w-5xl w-full mx-auto px-6 py-8">
      <% if notice %>
        <div class="mb-6 px-4 py-2.5 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-sm rounded flex items-start gap-2">
          <%# Check icon %>
          <svg class="w-4 h-4 mt-0.5 shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.5 8.5l3.5 3.5 7.5-8"/>
          </svg>
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="mb-6 px-4 py-2.5 bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded flex items-start gap-2">
          <%# Warning icon %>
          <svg class="w-4 h-4 mt-0.5 shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 2L14.5 13.5H1.5L8 2z"/>
            <path stroke-linecap="round" d="M8 6.5v3M8 11.5v.5"/>
          </svg>
          <%= alert %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="border-t border-zinc-800/60 mt-auto">
      <div class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-between">
        <span class="text-xs text-zinc-700 font-mono">coldwatch</span>
        <span class="text-xs text-zinc-700 font-mono">not a wallet &middot; watch-only</span>
      </div>
    </footer>
  </body>
</html>
