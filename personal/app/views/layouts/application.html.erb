<!DOCTYPE html>
<html class="bg-zinc-950">
  <head>
    <title><%= content_for(:title) || "coldwatch" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="color-scheme" content="dark">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-zinc-950 text-zinc-100 antialiased min-h-screen">
    <header class="border-b border-zinc-800 px-6 py-4">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <%= link_to root_path, class: "text-lg font-semibold tracking-tight text-zinc-100 hover:text-white" do %>
          coldwatch
        <% end %>
        <span class="text-xs text-zinc-500 uppercase tracking-wider">watch-only</span>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-8">
      <% if notice %>
        <div class="mb-6 px-4 py-2 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-sm rounded">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="mb-6 px-4 py-2 bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded">
          <%= alert %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
