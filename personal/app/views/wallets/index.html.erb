<div class="flex items-center justify-between mb-6">
  <h2 class="text-2xl font-semibold tracking-tight">Wallets</h2>
  <%= link_to "+ Add wallet", new_wallet_path,
        class: "px-4 py-2 bg-zinc-100 text-zinc-900 hover:bg-white text-sm font-medium rounded transition-colors" %>
</div>

<% if @wallets.any? %>
  <div class="space-y-3">
    <% @wallets.each do |wallet| %>
      <%= link_to wallet,
            class: "block bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded p-4 transition-colors" do %>
        <div class="flex items-center justify-between">
          <div>
            <div class="font-medium text-zinc-100"><%= wallet.name %></div>
            <div class="text-sm text-zinc-500 mt-1">
              <%= wallet.network %> · BIP84 · gap limit <%= wallet.gap_limit %>
            </div>
          </div>
          <span class="text-zinc-500">→</span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="bg-zinc-900 border border-zinc-800 rounded p-8 text-center">
    <p class="text-zinc-400">No wallets yet.</p>
    <p class="text-sm text-zinc-500 mt-2">Add one to start watching.</p>
  </div>
<% end %>
