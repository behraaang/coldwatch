<%# ================================================================
    Wallets index — editorial-meets-financial-tooling
    Empty state: oversized italic serif headline + bento feature strip
    Populated: substantive bento cards with mono meta + data row
    ================================================================ %>

<% if @wallets.any? %>

  <%# Populated header %>
  <div class="flex items-start justify-between mb-10 gap-4">
    <div>
      <h1 class="font-serif italic text-4xl text-ink leading-tight">Your wallets,&nbsp;<em>watched.</em></h1>
      <p class="text-xs text-stone-500 mt-2 font-mono tabular-nums">
        <%= @wallets.count %> <%= @wallets.count == 1 ? "wallet" : "wallets" %> watched
      </p>
    </div>
    <%= link_to new_wallet_path,
          class: "shrink-0 flex items-center gap-2 px-4 py-2.5 bg-orange-brand text-cream text-sm font-medium rounded-lg hover:bg-orange-brand-darker transition-colors focus:outline-none focus:ring-2 focus:ring-orange-brand/40 focus:ring-offset-2 focus:ring-offset-paper" do %>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 4.5v15m7.5-7.5h-15"/>
      </svg>
      Add wallet
    <% end %>
  </div>

  <%# Wallet bento cards %>
  <div class="space-y-3">
    <% @wallets.each do |wallet| %>
      <%= link_to wallet,
            class: "group block bg-cream border border-stone-200 rounded-xl transition-shadow duration-150 hover:shadow-[0_6px_20px_rgba(26,22,18,0.08),0_2px_6px_rgba(26,22,18,0.06)]",
            style: "box-shadow: 0 1px 3px rgba(26,22,18,0.04), 0 1px 2px rgba(26,22,18,0.06)" do %>
        <div class="px-6 py-5">

          <%# Top row: status dot + name + chevron %>
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2.5">
              <% if wallet.synced? %>
                <span class="h-2 w-2 rounded-full bg-sage shrink-0" title="Synced"></span>
              <% else %>
                <span class="h-2 w-2 rounded-full bg-orange-brand shrink-0 animate-pulse" title="Syncing"></span>
              <% end %>
              <span class="font-sans font-medium text-ink text-sm"><%= wallet.name %></span>
            </div>
            <%# Chevron right %>
            <svg class="w-4 h-4 text-stone-400 group-hover:text-stone-600 transition-colors shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
          </div>

          <%# Mono meta strip %>
          <div class="flex items-center gap-3 text-xs text-stone-500 font-mono mb-4">
            <span class="uppercase tracking-wide"><%= wallet.network %></span>
            <span class="text-stone-300">&middot;</span>
            <span>BIP84</span>
            <span class="text-stone-300">&middot;</span>
            <span>gap&thinsp;<%= wallet.gap_limit %></span>
          </div>

          <%# Data row: 3 columns with top divider %>
          <div class="pt-4 border-t border-stone-100 grid grid-cols-3 gap-4">
            <div>
              <div class="text-xs text-stone-500 mb-1">Balance</div>
              <div class="text-xs font-mono tabular-nums <%= wallet.balance_sats > 0 ? 'text-ink' : 'text-stone-400' %>">
                <%= format("%.8f", wallet.balance_btc).sub(/0+$/, "").sub(/\.$/, ".0") %>&thinsp;<span class="text-stone-400">BTC</span>
              </div>
            </div>
            <div>
              <div class="text-xs text-stone-500 mb-1">Used</div>
              <div class="text-xs text-ink font-mono tabular-nums">
                <%= wallet.addresses.used.count %>&thinsp;<span class="text-stone-400">/&thinsp;<%= wallet.addresses.count %></span>
              </div>
            </div>
            <div>
              <div class="text-xs text-stone-500 mb-1">Activity</div>
              <div class="text-xs text-ink font-mono tabular-nums"><%= wallet.total_tx_count %>&thinsp;<span class="text-stone-400">txs</span></div>
            </div>
          </div>

        </div>
      <% end %>
    <% end %>
  </div>

<% else %>

  <%# Empty state %>
  <div class="mb-12 max-w-xl">
    <h1 class="font-serif text-5xl text-ink leading-tight mb-4">
      Your wallets,<br><em>watched.</em>
    </h1>
    <p class="text-sm text-stone-600 leading-relaxed">
      Paste your xpub once. coldwatch derives every address and fires a sub-second alarm the moment an outgoing transaction hits the mempool — before it confirms.
    </p>
  </div>

  <%# Bento card — feature strip + CTA %>
  <div class="bg-cream border border-stone-200 rounded-xl overflow-hidden" style="box-shadow: 0 1px 3px rgba(26,22,18,0.04), 0 1px 2px rgba(26,22,18,0.06)">

    <%# Eye icon hero %>
    <div class="px-8 py-10 border-b border-stone-100">
      <div class="flex items-center gap-4 mb-6">
        <div class="p-3 bg-orange-brand/10 rounded-xl">
          <svg class="w-6 h-6 text-orange-brand" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z"/>
            <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs font-mono text-stone-500 uppercase tracking-wide mb-0.5">Watch-only sentinel</p>
          <p class="text-sm text-ink font-medium">No keys. No signing. Just watching.</p>
        </div>
      </div>

      <%= link_to new_wallet_path,
            class: "inline-flex items-center gap-2 px-5 py-2.5 bg-orange-brand text-cream text-sm font-medium rounded-lg hover:bg-orange-brand-darker transition-colors focus:outline-none focus:ring-2 focus:ring-orange-brand/40 focus:ring-offset-2 focus:ring-offset-cream" do %>
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 4.5v15m7.5-7.5h-15"/>
        </svg>
        Add your first wallet
      <% end %>
    </div>

    <%# Three-column feature strip %>
    <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-stone-100">
      <div class="px-6 py-5">
        <div class="text-xs font-mono text-stone-500 uppercase tracking-wide mb-1.5">Detection</div>
        <div class="text-sm text-ink leading-snug">Sub-second outgoing-tx alarm via ntfy</div>
      </div>
      <div class="px-6 py-5">
        <div class="text-xs font-mono text-stone-500 uppercase tracking-wide mb-1.5">Privacy</div>
        <div class="text-sm text-ink leading-snug">No keys, no signing &mdash; watch-only forever</div>
      </div>
      <div class="px-6 py-5">
        <div class="text-xs font-mono text-stone-500 uppercase tracking-wide mb-1.5">Coverage</div>
        <div class="text-sm text-ink leading-snug">BIP84 derivation, full gap-limit scan</div>
      </div>
    </div>

  </div>

<% end %>
