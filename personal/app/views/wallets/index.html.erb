<%# Page header row %>
<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight text-zinc-100">Wallets</h1>
    <p class="text-xs text-zinc-500 mt-1 font-mono"><%= @wallets.count %> watched</p>
  </div>
  <%= link_to new_wallet_path,
        class: "flex items-center gap-1.5 px-4 py-2 bg-zinc-100 text-zinc-900 hover:bg-white text-sm font-medium rounded transition-colors" do %>
    <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" d="M7 2v10M2 7h10"/>
    </svg>
    Add wallet
  <% end %>
</div>

<% if @wallets.any? %>
  <div class="space-y-2">
    <% @wallets.each do |wallet| %>
      <%= link_to wallet,
            class: "group block bg-zinc-900 border border-zinc-800 hover:border-zinc-600 rounded transition-colors duration-150" do %>
        <div class="px-5 py-4">
          <%# Top row: name + chevron %>
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2.5">
              <% dot_color = wallet.synced? ? "bg-emerald-500" : "bg-amber-400/70" %>
              <span class="h-2 w-2 rounded-full <%= dot_color %> shrink-0"></span>
              <span class="font-medium text-zinc-100 text-sm"><%= wallet.name %></span>
            </div>
            <svg class="w-4 h-4 text-zinc-600 group-hover:text-zinc-400 transition-colors" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 4l4 4-4 4"/>
            </svg>
          </div>

          <%# Meta strip %>
          <div class="flex items-center gap-4 text-xs text-zinc-500 font-mono">
            <span class="uppercase tracking-wide"><%= wallet.network %></span>
            <span class="text-zinc-700">&middot;</span>
            <span>BIP84</span>
            <span class="text-zinc-700">&middot;</span>
            <span>gap&nbsp;<%= wallet.gap_limit %></span>
          </div>

          <%# Real data row %>
          <div class="mt-3 pt-3 border-t border-zinc-800/60 grid grid-cols-3 gap-3">
            <div>
              <div class="text-xs text-zinc-600 mb-0.5">Balance</div>
              <div class="text-xs font-mono tabular-nums <%= wallet.balance_sats > 0 ? 'text-zinc-100' : 'text-zinc-500' %>">
                <%= format("%.8f", wallet.balance_btc).sub(/0+$/, "").sub(/\.$/, ".0") %> BTC
              </div>
            </div>
            <div>
              <div class="text-xs text-zinc-600 mb-0.5">Used / total</div>
              <div class="text-xs text-zinc-300 font-mono tabular-nums">
                <%= wallet.addresses.used.count %> / <%= wallet.addresses.count %>
              </div>
            </div>
            <div>
              <div class="text-xs text-zinc-600 mb-0.5">Activity</div>
              <div class="text-xs text-zinc-300 font-mono tabular-nums"><%= wallet.total_tx_count %> txs</div>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

<% else %>
  <%# Intentional zero state %>
  <div class="bg-zinc-900 border border-zinc-800 rounded">
    <div class="px-6 py-10 text-center">
      <div class="flex justify-center mb-5">
        <div class="p-3 bg-zinc-800 rounded-full">
          <svg class="w-6 h-6 text-zinc-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
      </div>

      <h2 class="text-sm font-medium text-zinc-300 mb-1">No wallets yet</h2>
      <p class="text-xs text-zinc-500 max-w-xs mx-auto leading-relaxed mb-6">
        Paste your xpub once. coldwatch watches every derived address and fires a sub-second alarm the moment an outgoing tx hits the mempool.
      </p>

      <%= link_to new_wallet_path,
            class: "inline-flex items-center gap-1.5 px-4 py-2 bg-zinc-100 text-zinc-900 hover:bg-white text-sm font-medium rounded transition-colors" do %>
        <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" d="M7 2v10M2 7h10"/>
        </svg>
        Add your first wallet
      <% end %>
    </div>

    <div class="border-t border-zinc-800 grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-zinc-800">
      <div class="px-5 py-4">
        <div class="text-xs text-zinc-500 font-mono uppercase tracking-wide mb-1">Detection</div>
        <div class="text-xs text-zinc-400">Sub-second outgoing-tx alarm via ntfy</div>
      </div>
      <div class="px-5 py-4">
        <div class="text-xs text-zinc-500 font-mono uppercase tracking-wide mb-1">Privacy</div>
        <div class="text-xs text-zinc-400">No keys, no signing &mdash; watch-only forever</div>
      </div>
      <div class="px-5 py-4">
        <div class="text-xs text-zinc-500 font-mono uppercase tracking-wide mb-1">Coverage</div>
        <div class="text-xs text-zinc-400">BIP84 derivation, full gap limit scan</div>
      </div>
    </div>
  </div>
<% end %>
