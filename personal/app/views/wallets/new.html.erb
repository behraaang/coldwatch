<div class="mb-6">
  <%= link_to "← All wallets", wallets_path,
        class: "text-sm text-zinc-400 hover:text-zinc-200" %>
</div>

<h2 class="text-2xl font-semibold tracking-tight mb-6">Add wallet</h2>

<%= form_with model: @wallet, class: "space-y-6 max-w-2xl" do |f| %>
  <% if @wallet.errors.any? %>
    <div class="px-4 py-3 bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded">
      <p class="font-medium mb-1">
        <%= pluralize(@wallet.errors.count, "error") %> prevented saving:
      </p>
      <ul class="list-disc pl-5 space-y-1">
        <% @wallet.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-zinc-300 mb-2" %>
    <%= f.text_field :name,
          class: "w-full bg-zinc-900 border border-zinc-800 rounded px-3 py-2 text-zinc-100 focus:border-zinc-600 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :network, class: "block text-sm font-medium text-zinc-300 mb-2" %>
    <%= f.select :network, [["mainnet", "mainnet"], ["testnet", "testnet"]], {},
          class: "w-full bg-zinc-900 border border-zinc-800 rounded px-3 py-2 text-zinc-100 focus:border-zinc-600 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :xpub, "BIP84 xpub (zpub for mainnet, vpub for testnet)",
          class: "block text-sm font-medium text-zinc-300 mb-2" %>
    <%= f.text_area :xpub, rows: 4,
          class: "w-full bg-zinc-900 border border-zinc-800 rounded px-3 py-2 text-zinc-100 font-mono text-xs focus:border-zinc-600 focus:outline-none",
          placeholder: "zpub6..." %>
    <p class="text-xs text-zinc-500 mt-2">
      Watch-only. Never paste a private key or seed phrase. The xpub is encrypted at rest.
    </p>
  </div>

  <div>
    <%= f.label :gap_limit, class: "block text-sm font-medium text-zinc-300 mb-2" %>
    <%= f.number_field :gap_limit, min: 1, max: 100,
          class: "w-full bg-zinc-900 border border-zinc-800 rounded px-3 py-2 text-zinc-100 focus:border-zinc-600 focus:outline-none" %>
    <p class="text-xs text-zinc-500 mt-2">
      Default 20 (Ledger Live default). Increase if you've used more than 20 receive addresses.
    </p>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit "Add wallet",
          class: "px-4 py-2 bg-zinc-100 text-zinc-900 hover:bg-white text-sm font-medium rounded cursor-pointer transition-colors" %>
    <%= link_to "Cancel", wallets_path,
          class: "text-sm text-zinc-400 hover:text-zinc-200" %>
  </div>
<% end %>
