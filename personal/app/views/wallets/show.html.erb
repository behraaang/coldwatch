<%# Breadcrumb %>
<div class="mb-8">
  <%= link_to wallets_path,
        class: "inline-flex items-center gap-1.5 text-xs text-zinc-500 hover:text-zinc-300 font-mono transition-colors" do %>
    <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 2L4 6l4 4"/>
    </svg>
    All wallets
  <% end %>
</div>

<%# Wallet identity + balance placeholder row %>
<div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-8">
  <div>
    <div class="flex items-center gap-2.5 mb-1">
      <%# Status dot — amber = pending watcher activation %>
      <span class="h-2.5 w-2.5 rounded-full bg-amber-400/70 shrink-0"></span>
      <h1 class="text-3xl font-semibold tracking-tight text-zinc-100"><%= @wallet.name %></h1>
    </div>
    <div class="flex items-center gap-3 text-xs text-zinc-500 font-mono ml-5">
      <span class="uppercase"><%= @wallet.network %></span>
      <span class="text-zinc-700">&middot;</span>
      <span>BIP84 Native SegWit</span>
      <span class="text-zinc-700">&middot;</span>
      <span>gap&nbsp;<%= @wallet.gap_limit %></span>
    </div>
  </div>

  <%# Balance card — Day-3 placeholder %>
  <div class="sm:text-right bg-zinc-900 border border-zinc-800 rounded px-5 py-3 min-w-[160px]">
    <div class="text-xs text-zinc-600 uppercase tracking-wide font-mono mb-1">Balance</div>
    <div class="text-2xl font-mono tabular-nums text-zinc-500 tracking-tight">&mdash; BTC</div>
    <div class="text-xs text-zinc-700 font-mono tabular-nums mt-0.5">&mdash; USD</div>
  </div>
</div>

<%# Stats strip — Day-3 placeholder %>
<div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-zinc-800 border border-zinc-800 rounded overflow-hidden mb-8">
  <div class="bg-zinc-900 px-4 py-3">
    <div class="text-xs text-zinc-600 font-mono uppercase tracking-wide mb-1">UTXOs</div>
    <div class="text-sm font-mono tabular-nums text-zinc-500">&mdash;</div>
  </div>
  <div class="bg-zinc-900 px-4 py-3">
    <div class="text-xs text-zinc-600 font-mono uppercase tracking-wide mb-1">Last event</div>
    <div class="text-sm font-mono text-zinc-500">&mdash;</div>
  </div>
  <div class="bg-zinc-900 px-4 py-3">
    <div class="text-xs text-zinc-600 font-mono uppercase tracking-wide mb-1">Addresses watched</div>
    <div class="text-sm font-mono tabular-nums text-zinc-500">
      <%= ((@receive_addresses || []).length + (@change_addresses || []).length) %>
    </div>
  </div>
  <div class="bg-zinc-900 px-4 py-3">
    <div class="text-xs text-zinc-600 font-mono uppercase tracking-wide mb-1">Alarm</div>
    <div class="text-xs font-mono text-zinc-600">not active</div>
  </div>
</div>

<% if @derivation_error %>
  <div class="mb-6 px-4 py-4 bg-red-500/10 border border-red-500/30 rounded flex items-start gap-3">
    <svg class="w-4 h-4 text-red-400 mt-0.5 shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 1.5L14.5 13H1.5L8 1.5z"/>
      <path stroke-linecap="round" d="M8 6v3.5"/>
      <circle cx="8" cy="11.5" r="0.5" fill="currentColor" stroke="none"/>
    </svg>
    <div>
      <p class="text-red-400 font-medium text-sm mb-1">Derivation failed</p>
      <p class="font-mono text-xs text-red-300/80 break-all"><%= @derivation_error %></p>
    </div>
  </div>
<% else %>
  <%# Address columns — receive has stronger visual signal %>
  <div class="grid md:grid-cols-2 gap-4">

    <%# Receive addresses — primary column %>
    <div class="bg-zinc-900 border border-zinc-800 rounded overflow-hidden">
      <div class="px-5 py-3 border-b border-zinc-800 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <%# Receive icon: arrow down-left %>
          <svg class="w-3.5 h-3.5 text-emerald-500" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 3L3 11M3 11h6M3 11V5"/>
          </svg>
          <span class="text-xs font-medium text-zinc-300 uppercase tracking-wide">Receive</span>
        </div>
        <span class="text-xs text-zinc-600 font-mono">m/84&rsquo;/0&rsquo;/0&rsquo;/0/i</span>
      </div>

      <div class="divide-y divide-zinc-800/50">
        <% (@receive_addresses || []).each do |a| %>
          <div class="group flex items-center gap-3 px-5 py-2.5">
            <span class="text-xs text-zinc-600 font-mono tabular-nums w-8 shrink-0"><%= a[:path].to_s.split("/").last %></span>
            <span class="text-xs text-zinc-300 font-mono truncate flex-1 min-w-0"><%= a[:address] %></span>
            <%# Copy button — static for now, JS clipboard in Day-4 Stimulus pass %>
            <button
              type="button"
              onclick="navigator.clipboard.writeText('<%= a[:address] %>')"
              title="Copy address"
              class="shrink-0 opacity-0 group-hover:opacity-100 p-1 text-zinc-600 hover:text-zinc-300 rounded transition-all focus:opacity-100 focus:outline-none focus:ring-1 focus:ring-zinc-500"
              aria-label="Copy <%= a[:address] %>">
              <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="5" y="5" width="7" height="7" rx="1"/>
                <path stroke-linecap="round" d="M9 5V3a1 1 0 00-1-1H3a1 1 0 00-1 1v5a1 1 0 001 1h2"/>
              </svg>
            </button>
          </div>
        <% end %>
      </div>
    </div>

    <%# Change addresses — secondary column, visually muted %>
    <div class="bg-zinc-900 border border-zinc-800/60 rounded overflow-hidden opacity-80">
      <div class="px-5 py-3 border-b border-zinc-800/60 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <%# Change icon: arrow up-right looping back %>
          <svg class="w-3.5 h-3.5 text-zinc-500" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 11L11 3M11 3H5M11 3v6"/>
          </svg>
          <span class="text-xs font-medium text-zinc-500 uppercase tracking-wide">Change</span>
        </div>
        <span class="text-xs text-zinc-700 font-mono">m/84&rsquo;/0&rsquo;/0&rsquo;/1/i</span>
      </div>

      <div class="divide-y divide-zinc-800/30">
        <% (@change_addresses || []).each do |a| %>
          <div class="group flex items-center gap-3 px-5 py-2.5">
            <span class="text-xs text-zinc-700 font-mono tabular-nums w-8 shrink-0"><%= a[:path].to_s.split("/").last %></span>
            <span class="text-xs text-zinc-500 font-mono truncate flex-1 min-w-0"><%= a[:address] %></span>
            <button
              type="button"
              onclick="navigator.clipboard.writeText('<%= a[:address] %>')"
              title="Copy address"
              class="shrink-0 opacity-0 group-hover:opacity-100 p-1 text-zinc-700 hover:text-zinc-400 rounded transition-all focus:opacity-100 focus:outline-none focus:ring-1 focus:ring-zinc-600"
              aria-label="Copy <%= a[:address] %>">
              <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="5" y="5" width="7" height="7" rx="1"/>
                <path stroke-linecap="round" d="M9 5V3a1 1 0 00-1-1H3a1 1 0 00-1 1v5a1 1 0 001 1h2"/>
              </svg>
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <p class="text-xs text-zinc-700 mt-4 font-mono">
    Showing first <%= (@receive_addresses || []).length %> receive / <%= (@change_addresses || []).length %> change addresses &mdash; Day-3 persists full gap-limit derivation.
  </p>
<% end %>
