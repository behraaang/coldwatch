<div class="mb-6">
  <%= link_to "← All wallets", wallets_path,
        class: "text-sm text-zinc-400 hover:text-zinc-200" %>
</div>

<h2 class="text-2xl font-semibold tracking-tight mb-2"><%= @wallet.name %></h2>
<p class="text-sm text-zinc-500 mb-8 tabular-nums">
  <%= @wallet.network %> · BIP84 Native SegWit · gap limit <%= @wallet.gap_limit %>
</p>

<% if @derivation_error %>
  <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/30 rounded">
    <p class="text-red-400 font-medium text-sm">Derivation failed</p>
    <p class="font-mono text-xs text-red-300 mt-2"><%= @derivation_error %></p>
  </div>
<% else %>
  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-zinc-900 border border-zinc-800 rounded p-5">
      <h3 class="text-sm font-medium text-zinc-300 mb-4 flex items-center justify-between">
        <span>Receive addresses</span>
        <span class="text-xs text-zinc-500 font-mono">m/.../0/i</span>
      </h3>
      <div class="space-y-2 font-mono text-xs">
        <% (@receive_addresses || []).each do |a| %>
          <div class="flex items-center justify-between border-b border-zinc-800/50 pb-2 last:border-0 last:pb-0">
            <span class="text-zinc-500 tabular-nums"><%= a[:path] %></span>
            <span class="text-zinc-300 truncate ml-3"><%= a[:address] %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="bg-zinc-900 border border-zinc-800 rounded p-5">
      <h3 class="text-sm font-medium text-zinc-300 mb-4 flex items-center justify-between">
        <span>Change addresses</span>
        <span class="text-xs text-zinc-500 font-mono">m/.../1/i</span>
      </h3>
      <div class="space-y-2 font-mono text-xs">
        <% (@change_addresses || []).each do |a| %>
          <div class="flex items-center justify-between border-b border-zinc-800/50 pb-2 last:border-0 last:pb-0">
            <span class="text-zinc-500 tabular-nums"><%= a[:path] %></span>
            <span class="text-zinc-300 truncate ml-3"><%= a[:address] %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <p class="text-xs text-zinc-500 mt-6">
    Showing the first 5 of each branch. Day-3 work persists derived addresses up to the gap limit.
  </p>
<% end %>
