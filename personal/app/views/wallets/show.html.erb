<%# ================================================================
    Wallet show — editorial-meets-financial-tooling
    Serif italic page title, mono numeric hero, bento stats strip
    turbo_stream_from must remain for live updates
    ================================================================ %>

<%# Live update subscription — Day 4 wiring, must stay %>
<%= turbo_stream_from @wallet %>

<%# Breadcrumb %>
<div class="mb-8">
  <%= link_to wallets_path,
        class: "inline-flex items-center gap-1.5 text-xs text-stone-500 hover:text-ink font-mono transition-colors focus:outline-none focus:ring-2 focus:ring-orange-brand/40 focus:rounded" do %>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M15.75 19.5L8.25 12l7.5-7.5"/>
    </svg>
    All wallets
  <% end %>
</div>

<%# Wallet identity row — title + balance card side by side on sm+ %>
<div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6 mb-8">

  <%# Left: title + meta %>
  <div>
    <div class="flex items-center gap-2.5 mb-1.5">
      <% if @wallet.synced? %>
        <span class="h-2.5 w-2.5 rounded-full bg-sage shrink-0" title="Synced" aria-label="Synced"></span>
      <% else %>
        <span class="h-2.5 w-2.5 rounded-full bg-orange-brand shrink-0 animate-pulse" title="Syncing" aria-label="Syncing"></span>
      <% end %>
      <h1 class="font-serif italic text-4xl text-ink leading-tight"><%= @wallet.name %></h1>
    </div>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-stone-500 font-mono ml-5">
      <span class="uppercase tracking-wide"><%= @wallet.network %></span>
      <span class="text-stone-300">&middot;</span>
      <span>BIP84 Native SegWit</span>
      <span class="text-stone-300">&middot;</span>
      <span>gap&thinsp;<%= @wallet.gap_limit %></span>
      <% if @wallet.last_synced_at %>
        <span class="text-stone-300">&middot;</span>
        <span>synced <%= time_ago_in_words(@wallet.last_synced_at) %> ago</span>
      <% end %>
    </div>
  </div>

  <%# Right: balance card (Turbo-Stream targeted) %>
  <%= render "balance_card", wallet: @wallet %>
</div>

<%# Stats strip — 4-cell bento, cream bg, stone-200 dividers %>
<div class="bg-cream border border-stone-200 rounded-xl overflow-hidden mb-8" style="box-shadow: 0 1px 3px rgba(26,22,18,0.04), 0 1px 2px rgba(26,22,18,0.06)">
  <div class="grid grid-cols-2 sm:grid-cols-4 divide-y sm:divide-y-0 sm:divide-x divide-stone-100">

    <div class="px-5 py-4">
      <div class="text-xs text-stone-500 font-mono uppercase tracking-wide mb-1.5">Activity</div>
      <div class="text-sm font-mono tabular-nums text-ink"><%= @wallet.total_tx_count %>&thinsp;<span class="text-stone-400">txs</span></div>
    </div>

    <div class="px-5 py-4">
      <div class="text-xs text-stone-500 font-mono uppercase tracking-wide mb-1.5">Used / total</div>
      <div class="text-sm font-mono tabular-nums text-ink">
        <%= @wallet.addresses.used.count %>&thinsp;<span class="text-stone-400">/&thinsp;<%= @wallet.addresses.count %></span>
      </div>
    </div>

    <div class="px-5 py-4">
      <div class="text-xs text-stone-500 font-mono uppercase tracking-wide mb-1.5">UTXOs</div>
      <div class="text-sm font-mono tabular-nums text-ink">
        <%= @wallet.utxo_count %>
        <% if (dust = @wallet.utxos.dust.count) > 0 %>
          <span class="text-stone-400">(<%= dust %> dust)</span>
        <% end %>
      </div>
    </div>

    <div class="px-5 py-4">
      <div class="text-xs text-stone-500 font-mono uppercase tracking-wide mb-1.5">Alarm</div>
      <% if @wallet.ntfy_topic.present? %>
        <div class="text-sm font-mono text-sage flex items-center gap-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-sage"></span>
          armed
        </div>
      <% else %>
        <div class="text-xs font-serif italic text-stone-400">not configured</div>
      <% end %>
    </div>

  </div>
</div>

<%# Fee monitor card — only when threshold is configured %>
<% if @wallet.fee_threshold_sat_vb %>
  <% current = @current_fees&.dig(:fastestFee) %>
  <% in_window = current && current <= @wallet.fee_threshold_sat_vb %>
  <% in_cooldown = @wallet.last_fee_alert_at && @wallet.last_fee_alert_at > 1.hour.ago %>

  <div class="mb-8">
    <h2 class="font-sans font-medium text-sm text-ink mb-4">
      Fee window
      <% if in_window %>
        <span class="ml-1 inline-flex items-center gap-1 text-xs font-mono text-sage uppercase tracking-wide">
          <span class="h-1.5 w-1.5 rounded-full bg-sage"></span>open
        </span>
      <% else %>
        <span class="ml-1 inline-flex items-center gap-1 text-xs font-mono text-stone-400 uppercase tracking-wide">
          <span class="h-1.5 w-1.5 rounded-full bg-stone-400"></span>waiting
        </span>
      <% end %>
    </h2>

    <div class="bg-cream <%= in_window ? 'border border-sage/30' : 'border border-stone-200' %> rounded-xl overflow-hidden" style="box-shadow: 0 1px 3px rgba(26,22,18,0.04), 0 1px 2px rgba(26,22,18,0.06)">
      <div class="grid grid-cols-2 sm:grid-cols-4 divide-y sm:divide-y-0 sm:divide-x divide-stone-100">

        <%# Current fee %>
        <div class="px-5 py-4">
          <div class="text-xs text-stone-500 font-mono uppercase tracking-wide mb-1.5">Current</div>
          <% if current %>
            <div class="text-lg font-mono tabular-nums leading-none <%= in_window ? 'text-sage' : 'text-ink' %>">
              <%= current %>
              <span class="text-xs text-stone-400 font-mono">sat/vB</span>
            </div>
          <% else %>
            <div class="text-sm font-serif italic text-stone-400">unavailable</div>
          <% end %>
        </div>

        <%# Threshold %>
        <div class="px-5 py-4">
          <div class="text-xs text-stone-500 font-mono uppercase tracking-wide mb-1.5">Threshold</div>
          <div class="text-lg font-mono tabular-nums text-ink leading-none">
            <%= @wallet.fee_threshold_sat_vb %>
            <span class="text-xs text-stone-400 font-mono">sat/vB</span>
          </div>
        </div>

        <%# Last alert %>
        <div class="px-5 py-4">
          <div class="text-xs text-stone-500 font-mono uppercase tracking-wide mb-1.5">Last alert</div>
          <% if @wallet.last_fee_alert_at %>
            <div class="text-sm font-mono text-stone-600">
              <%= time_ago_in_words(@wallet.last_fee_alert_at) %> ago
            </div>
            <% if in_cooldown %>
              <div class="text-xs text-stone-400 font-serif italic mt-0.5">cooldown</div>
            <% end %>
          <% else %>
            <div class="text-sm font-serif italic text-stone-400">never</div>
          <% end %>
        </div>

        <%# Push channel %>
        <div class="px-5 py-4">
          <div class="text-xs text-stone-500 font-mono uppercase tracking-wide mb-1.5">Channel</div>
          <% if @wallet.ntfy_topic.present? %>
            <div class="text-sm font-mono text-sage flex items-center gap-1.5">
              <span class="h-1.5 w-1.5 rounded-full bg-sage"></span>ntfy
            </div>
          <% else %>
            <div class="text-xs font-serif italic text-rust">no ntfy topic</div>
          <% end %>
        </div>

      </div>

      <%# Status footer %>
      <% if in_window && @wallet.ntfy_topic.present? %>
        <div class="px-5 py-3 border-t border-sage/20 bg-sage/5 text-xs text-sage font-mono">
          <% if in_cooldown %>
            Window open. Already pushed within the last hour — cooldown active.
          <% else %>
            Window open. Next FeeMonitorJob run will push an alert.
          <% end %>
        </div>
      <% elsif in_window %>
        <div class="px-5 py-3 border-t border-stone-100 bg-stone-50 text-xs text-stone-500 font-mono">
          Window open, but no ntfy topic set — alert won't fire. Add one to enable.
        </div>
      <% end %>
    </div>

    <p class="text-xs text-stone-400 mt-2 font-mono">
      FeeMonitorJob runs every 5 minutes. Cache TTL on the current-fee read is 60s.
    </p>
  </div>
<% end %>

<%# Alarm history — recent outgoing-tx detections %>
<% if @alert_events.any? %>
  <div class="mb-8">
    <h2 class="font-sans font-medium text-sm text-ink mb-4">
      Alarm log
      <span class="font-mono text-stone-400 font-normal text-xs ml-1">(<%= @wallet.alert_events.count %> total)</span>
    </h2>
    <div class="bg-cream border border-rust/20 rounded-xl overflow-hidden" style="box-shadow: 0 1px 3px rgba(162,64,47,0.06), 0 1px 2px rgba(26,22,18,0.05)">
      <div class="divide-y divide-stone-100">
        <% @alert_events.each do |event| %>
          <div class="px-5 py-3 flex items-center gap-4">
            <%# Direction icon — rust-colored arrow-up-right for outgoing %>
            <div class="shrink-0 p-1.5 bg-rust/10 rounded-lg">
              <svg class="w-3.5 h-3.5 text-rust" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
              </svg>
            </div>

            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-0.5">
                <span class="text-xs font-medium text-rust uppercase tracking-wide">Outgoing</span>
                <% if event.confirmed %>
                  <span class="text-xs text-stone-400 font-mono">confirmed @ <%= event.block_height %></span>
                <% else %>
                  <span class="text-xs text-orange-brand-darker font-mono italic">unconfirmed (mempool)</span>
                <% end %>
              </div>
              <div class="flex items-center gap-3 text-xs">
                <% if event.amount_btc %>
                  <span class="font-mono tabular-nums text-ink">
                    <%= format("%.8f", event.amount_btc).sub(/0+$/, "").sub(/\.$/, ".0") %>&thinsp;<span class="text-stone-400">BTC</span>
                  </span>
                  <span class="text-stone-300">&middot;</span>
                <% end %>
                <a href="<%= event.mempool_url %>" target="_blank" rel="noopener"
                   class="font-mono text-stone-500 hover:text-ink transition-colors truncate">
                  <%= event.short_txid %>
                </a>
              </div>
            </div>

            <div class="shrink-0 text-right">
              <% if event.dispatched_at %>
                <div class="text-xs text-stone-400 font-mono"><%= time_ago_in_words(event.dispatched_at) %> ago</div>
                <div class="text-xs text-sage font-mono">pushed</div>
              <% else %>
                <div class="text-xs text-stone-400 font-mono"><%= time_ago_in_words(event.created_at) %> ago</div>
                <div class="text-xs text-stone-400 italic font-serif">no channel</div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# UTXO map — what's actually spendable %>
<% if @utxos.any? %>
  <div class="mb-8">
    <h2 class="font-sans font-medium text-sm text-ink mb-4">
      UTXOs
      <span class="font-mono text-stone-400 font-normal text-xs ml-1">(<%= @wallet.utxo_count %> total<%= ", #{@wallet.utxos.dust.count} dust" if @wallet.utxos.dust.count.positive? %>)</span>
    </h2>
    <div class="bg-cream border border-stone-200 rounded-xl overflow-hidden" style="box-shadow: 0 1px 3px rgba(26,22,18,0.04), 0 1px 2px rgba(26,22,18,0.06)">
      <div class="divide-y divide-stone-100">
        <% @utxos.each do |u| %>
          <div class="px-5 py-2.5 flex items-center gap-3 <%= u.dust? ? 'bg-stone-50' : '' %>">
            <span class="text-xs font-mono tabular-nums w-32 shrink-0 <%= u.value_sats > 0 ? 'text-ink' : 'text-stone-400' %>">
              <%= format("%.8f", u.value_btc).sub(/0+$/, "").sub(/\.$/, ".0") %>
              <span class="text-stone-400">BTC</span>
            </span>
            <% if u.dust? %>
              <span class="text-xs font-serif italic text-stone-500 shrink-0" title="costs more to spend than it's worth at typical fees">dust</span>
            <% end %>
            <% unless u.confirmed %>
              <span class="text-xs font-mono text-orange-brand-darker italic shrink-0">mempool</span>
            <% end %>
            <span class="text-xs font-mono text-stone-500 truncate flex-1 min-w-0" title="<%= u.address.address %>">
              <%= u.address.address %>
            </span>
            <a href="<%= u.mempool_url %>" target="_blank" rel="noopener"
               class="text-xs font-mono text-stone-400 hover:text-ink shrink-0">
              <%= u.short_txid %>
            </a>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# Addresses panel (Turbo-Stream targeted) %>
<%= render "addresses_panel",
      wallet: @wallet,
      receive_addresses: @receive_addresses,
      change_addresses: @change_addresses %>
