# Personal stack environment — copy to .env, fill in real values, NEVER commit .env.

# Rails
RAILS_MASTER_KEY=replace-with-output-of-rails-credentials-edit
SECRET_KEY_BASE=replace-with-output-of-bin-rails-secret

# Postgres
POSTGRES_PASSWORD=generate-a-strong-random-password

# ntfy.sh
NTFY_TOPIC=coldwatch-personal-replace-with-long-random-string
NTFY_E2E_KEY=replace-with-32-byte-base64-key

# Email heartbeat fallback (when ntfy stops responding)
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
HEARTBEAT_EMAIL_TO=you@example.com

# Chain provider
CHAIN_PROVIDER=mempool_space
# v2: switch to bitcoin_core when running your own node:
# CHAIN_PROVIDER=bitcoin_core
# BITCOIN_RPC_URL=http://bitcoin:8332
# BITCOIN_RPC_USER=
# BITCOIN_RPC_PASSWORD=

# Confirmation thresholds
ALARM_CONFIRMATIONS=0
SETTLED_CONFIRMATIONS=6

# Auth
DASHBOARD_USERNAME=replace
DASHBOARD_PASSWORD=replace-with-long-random-passphrase
