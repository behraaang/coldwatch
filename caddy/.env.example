# Caddy environment — copy to .env, fill in, NEVER commit .env.

# Your domain (without protocol or subdomain)
DOMAIN=example.com

# Your home IP for the personal-instance allowlist.
# Find with: curl -4 ifconfig.io
# Use CIDR notation: single IP is /32. Add multiple with spaces.
HOME_IP=1.2.3.4/32

# Email for Let's Encrypt expiry warnings
ACME_EMAIL=you@example.com
